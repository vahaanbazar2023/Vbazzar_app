  "policy_title": "Unified Terms of Use, Privacy & Auction Policy",
  "policy_intro_text_1": "This document governs your use of our vehicle auction platform and related services (the \"Platform\").",
  "policy_intro_text_2": "It consolidates the terms of use, privacy policies, and auction procedures for all users (\"Buyers\" and \"Sellers\").",
  "section_1_heading": "1. Legal Notice",
  "section_1_text_1": "This is an electronic record as per the Information Technology Act, 2000.",
  "section_1_text_2": "Use of the Platform confirms your acceptance of these terms.",
  "section_2_heading": "2. Definitions",
  "definition_user": "• User: Any registered individual or entity on the Platform.",
  "definition_auction_buyer": "• Auction Buyer: Any person or business placing bids on vehicles.",
  "definition_seller": "• Seller: Any person or business listing vehicles for auction.",
  "definition_platform": "• Platform: The digital interface (website/app) that facilitates online vehicle auctions. i.e. Vahaan Bazar Private Limited.",
  "section_3_heading": "3. Eligibility & Registration",
  "eligibility_text_1": "• Users must be 18 years or older.",
  "eligibility_text_2": "• Business users must be authorized to represent their organization.",
  "eligibility_text_3": "• Accurate, updated registration details are mandatory.",
  "eligibility_text_4": "• Platform reserves the right to reject or terminate access at its discretion.",
  "section_4_heading": "4. Account Responsibilities",
  "account_responsibility_text_1": "• Keep login credentials secure.",
  "account_responsibility_text_2": "• Do not create multiple accounts to circumvent restrictions.",
  "account_responsibility_text_3": "• Users are responsible for all activities under their registered ID.",
  "section_5_heading": "5. Privacy Policy",
  "privacy_policy_intro": "We collect and process user data including:",
  "privacy_data_collected_1": "• Name, contact details, Browse history, payment records.",
  "privacy_data_used_for": "• Used to provide services, personalize content, detect fraud, and improve security.",
  "privacy_user_rights": "• Users have the right to access, update, or delete their data by contacting support.",
  "section_6_heading": "6. Use of Platform",
  "use_platform_text_1": "• The Platform facilitates transactions; it is not a party to the sale contract.",
  "use_platform_text_2": "• Buyers must independently inspect vehicles and verify information.",
  "use_platform_text_3": "• All listings are strictly \"As-Is-Where-Is\".",
  "section_7_heading": "7. Auction & Bidding Rules",
  "bidding_rules_text_1": "• All bids are legally binding.",
  "bidding_rules_text_2": "• Highest bid (price + earliest time) prevails.",
  "bidding_rules_text_3": "• Bids may be rejected if found suspicious.",
  "bidding_rules_text_4": "• Sellers have final discretion over sale acceptance.",
  "section_8_heading": "8. Vehicle Inspection",
  "vehicle_inspection_text_1": "• Vehicle condition certifications are indicative only.",
  "vehicle_inspection_text_2": "• Buyers must inspect vehicles themselves and verify liabilities (taxes, fines, etc.).",
  "vehicle_inspection_text_3": "• The Platform does not guarantee listing accuracy.",
  "section_9_heading": "9. Payments",
  "payments_text_1": "• Payment is due within the specified timeline (e.g., 5–7 working days).",
  "payments_text_2": "• Buyers pay applicable taxes, parking charges, and RTO/GST/TCS dues.",
  "payments_text_3": "• Non-payment may lead to forfeiture or legal action.",
  "section_10_heading": "10. Ownership Transfer",
  "ownership_transfer_text_1": "• Buyers must transfer ownership within 60 days post-NOC/TTO issuance.",
  "ownership_transfer_text_2": "• Failure to comply may result in account blocking.",
  "ownership_transfer_text_3": "• Tax receipts may be required for vehicle release.",
  "section_11_heading": "11. Indemnity",
  "indemnity_intro": "Users agree to indemnify the Platform from all claims, penalties, or liabilities arising from:",
  "indemnity_item_1": "• Breach of terms",
  "indemnity_item_2": "• Law violations",
  "indemnity_item_3": "• Post-sale misuse of vehicles",
  "section_12_heading": "12. Limitation of Liability",
  "limitation_liability_text_1": "• Services are offered \"as-is.\"",
  "limitation_liability_text_2": "• Platform is not liable for delays, failures, or listing inaccuracies.",
  "limitation_liability_text_3": "• Maximum liability is limited to any service fee paid to the Platform.",
  "section_13_heading": "13. Intellectual Property",
  "intellectual_property_text": "All platform content (text, visuals, tools) is protected IP. No reproduction, distribution, or unauthorized usage is allowed.",
  "section_14_heading": "14. Dispute Resolution",
  "dispute_resolution_text_1": "• Indian law governs this agreement.",
  "dispute_resolution_text_2": "• Arbitration will be conducted in Hyderabad under the Arbitration & Conciliation Act, 1996.",
  "dispute_resolution_text_3": "• Each party bears its own legal costs unless otherwise specified.",
  "section_15_heading": "15. Notices",
  "notices_text_1": "• Official communication will be made via registered mail or email.",
  "notices_text_2": "• Users must keep their contact information current.",
  "policy_acknowledgement": "By continuing to use the Platform, you acknowledge that you have read, understood, and agreed to these unified terms of Vahaan Bazar Private Limited.",
